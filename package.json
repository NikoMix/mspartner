{
  "name": "ms-partner-resources",
  "version": "1.0.0",
  "private": true,
  "description": "Static Next.js app of curated getting-started links for Microsoft Partners. Links are managed via data/links.yaml.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck:e2e": "tsc -p tsconfig.e2e.json",
    "serve": "node scripts/serve-static.mjs out --port 3100",
    "test:e2e": "playwright test",
    "test:e2e:local": "cross-env E2E_LOCAL=1 playwright test",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "js-yaml": "^5.1.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
